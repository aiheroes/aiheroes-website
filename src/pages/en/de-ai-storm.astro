---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AIStormFeature from '../../components/AIStormFeature.astro';

const description =
  'AI Heroes on De AI Storm, as seen on RTL 7, RTL Z and Videoland. Watch our episode and discover how to take AI from idea to working solution.';

const videoSchema = {
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: 'AI Heroes on De AI Storm',
  description,
  thumbnailUrl: ['https://i.ytimg.com/vi/uq8MIcgzUR4/maxresdefault.jpg'],
  uploadDate: '2026-05-17',
  embedUrl: 'https://www.youtube-nocookie.com/embed/uq8MIcgzUR4',
  contentUrl: 'https://www.youtube.com/watch?v=uq8MIcgzUR4',
  publisher: { '@type': 'Organization', name: 'AI Heroes', url: 'https://aiheroes.io' },
};
---

<BaseLayout
  lang="en"
  title="AI Heroes on De AI Storm"
  seoTitle="AI Heroes on De AI Storm · RTL 7, RTL Z & Videoland"
  description={description}
  ogImage="https://i.ytimg.com/vi/uq8MIcgzUR4/maxresdefault.jpg"
  jsonLd={videoSchema}
>
  <AIStormFeature lang="en" />
</BaseLayout>

---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { PageContactForm } from '../../../../components/PageContactForm';
import { CONTENT } from '../../../data/content';
import CardGrid from '../../../components/blocks/CardGrid.astro';
import ProofRow from '../../../components/blocks/ProofRow.astro';

const content = CONTENT.nl.aboutPage;
const introParagraphs = content.intro.text.split('\n\n');
const readMore = 'Lees meer';

const pillars = [
  { title: 'Training', accent: 'red' as const, href: '/nl/diensten/training', description: 'Incompany workshops die je team van inzicht naar dagelijkse toepassing brengen.' },
  { title: 'Consultancy', accent: 'blue' as const, href: '/nl/diensten/consultancy', description: 'Van AI-readiness en business cases tot roadmap en implementatiebegeleiding.' },
  { title: 'Software', accent: 'dark' as const, href: '/nl/diensten/software', description: 'Van proof of concept tot maatwerk AI, integratie en digital twins.' },
];
const clients = ['Postcode Loterij', 'Tweede Kamer', 'Prosus', 'Medux', 'Envalior', 'InnoEnergy', 'OLX Poland', 'Banijay Benelux'];
---

<BaseLayout
  lang="nl"
  title={content.hero.title}
  description="Over AI Heroes: full-service AI agency vanuit Groningen. Sinds 2019 helpen we organisaties van change management tot technische implementatie."
>
  <header id="page-hero" class="pt-24 pb-12 md:pt-40 md:pb-24 bg-brand-dark border-b-4 border-brand-red">
    <div class="max-w-4xl mx-auto px-6">
      <h1 class="text-[clamp(1.875rem,_1.25rem+1.5vw,_3.75rem)] font-serif text-white mb-4">{content.hero.title}</h1>
      <p class="text-lg md:text-xl text-white/80 leading-relaxed max-w-2xl mb-8">{content.hero.subtitle}</p>
      <a href="/#contact" class="inline-flex items-center gap-3 bg-brand-red text-white px-8 py-4 font-medium hover:bg-opacity-90 transition-all shadow-lg">Start gesprek</a>
    </div>
  </header>

  <main>
    <section class="py-16 md:py-20 bg-brand-light px-6 md:px-12">
      <div class="max-w-4xl mx-auto">
        <div class="prose prose-lg max-w-none mb-12">
          {introParagraphs.map((p) => <p class="text-stone-700 leading-relaxed mb-6 text-lg">{p}</p>)}
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
          {content.intro.stats.map((stat) => (
            <div class="text-center">
              <div class="text-4xl md:text-5xl font-serif text-brand-red mb-2">{stat.metric}</div>
              <div class="text-sm text-stone-600 uppercase tracking-wider">{stat.description}</div>
            </div>
          ))}
        </div>
        <div class="mt-14">
          <ProofRow label="Vertrouwd door" items={clients} />
        </div>
      </div>
    </section>

    <section class="py-16 md:py-20 bg-white px-6 md:px-12">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-5xl font-serif text-brand-dark mb-3">{content.team.title}</h2>
        <p class="text-lg text-stone-600 mb-12">{content.team.subtitle}</p>
        <div class="space-y-8">
          {content.team.members.map((member) => (
            <div class="border-l-4 border-brand-red pl-6 py-2">
              <h3 class="text-xl md:text-2xl font-serif text-brand-dark mb-1">{member.name}</h3>
              <div class="text-sm text-brand-red font-medium uppercase tracking-wider mb-3">{member.role}</div>
              <p class="text-stone-700 leading-relaxed">{member.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 md:py-20 bg-brand-light px-6 md:px-12">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {content.cards.map((card) => (
            <a href={card.href} class="group bg-white p-8 hover:shadow-lg transition-all duration-300 border-l-4 border-brand-red no-underline">
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0">
                  <div class="w-12 h-12 bg-brand-red/10 flex items-center justify-center text-brand-red">
                    {card.icon === 'users' ? (
                      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    ) : (
                      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                    )}
                  </div>
                </div>
                <div class="flex-grow">
                  <h3 class="text-xl font-serif text-brand-dark mb-2 group-hover:text-brand-red transition-colors">{card.title}</h3>
                  <p class="text-stone-600 text-sm mb-3">{card.description}</p>
                  <div class="flex items-center gap-2 text-brand-red text-sm font-medium"><span>{readMore}</span><span class="group-hover:translate-x-1 transition-transform">→</span></div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 md:py-20 bg-brand-dark px-6 md:px-12">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-5xl font-serif text-white mb-12">{content.values.title}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {content.values.items.map((value) => (
            <div class="border-l-4 border-brand-red pl-6 py-2">
              <h3 class="text-xl font-serif text-white mb-3">{value.title}</h3>
              <p class="text-white/80 leading-relaxed">{value.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 md:py-20 bg-brand-light px-6 md:px-12">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-serif text-brand-dark mb-3">Wat we doen</h2>
        <p class="text-lg text-stone-600 mb-8">Drie pijlers, onder één dak. Van eerste inzicht tot werkende AI in productie.</p>
        <CardGrid items={pillars} cols={3} />
        <p class="mt-8 text-stone-600">Benieuwd naar het resultaat? <a href="/nl/cases" class="text-brand-red font-medium hover:underline underline-offset-2">Bekijk onze cases &rarr;</a></p>
      </div>
    </section>

    <section id="contact-form" class="py-16 md:py-24 bg-white border-t border-stone-200 px-6">
      <div class="max-w-4xl mx-auto">
        <PageContactForm lang="nl" accentColor="red" client:visible />
      </div>
    </section>
  </main>
</BaseLayout>

---
import { PageContactForm } from '../../components/PageContactForm';
import type { Lang } from '../data/i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// AI Heroes' item in De AI Storm (RTL 7 / RTL Z / Videoland).
const VIDEO_ID = 'uq8MIcgzUR4';
const contactHref = lang === 'nl' ? '/#contact' : '/en#contact';

// Official broadcaster marks, shown once as logos (the trust signal). RTL 7 + RTL Z
// as crisp vectors; Videoland as the current "videoland." wordmark.
const LOGOS = [
  { name: 'RTL 7', src: '/broadcasters/rtl7.svg' },
  { name: 'RTL Z', src: '/broadcasters/rtlz.svg' },
  { name: 'Videoland', src: '/broadcasters/videoland.png' },
];

interface Copy {
  h1: string;
  lead: string;
  cta: string;
  bridgeHeading: string;
  bridgeParas: string[];
  pull: string;
  offerings: { title: string; body: string }[];
  statNumber: string;
  statLabel: string;
}

const COPY: Record<Lang, Copy> = {
  nl: {
    h1: 'Zoals gezien op nationale televisie.',
    lead: 'AI Heroes in De AI Storm, over hoe Nederlandse organisaties AI inzetten die werkt. Bekijk de aflevering hieronder.',
    cta: 'Plan een kennismaking',
    bridgeHeading: 'Van het scherm naar jouw organisatie',
    bridgeParas: [
      'De AI Storm laat in vier afleveringen zien hoe organisaties AI inzetten als gereedschap. Iets dat processen vereenvoudigt, fouten vermindert en ruimte maakt voor het werk dat er echt toe doet.',
      'Wat je in onze aflevering ziet, doen we elke dag. We begeleiden organisaties van eerste verkenning tot werkende oplossing, met training, consultancy en software onder één dak.',
    ],
    pull: 'AI werkt als je weet hoe.',
    offerings: [
      { title: 'Training', body: 'Workshops en incompany-trainingen die teams AI-vaardig maken.' },
      { title: 'Consultancy', body: 'AI-readiness scans, roadmaps en business cases die richting geven.' },
      { title: 'Software', body: 'Maatwerk AI-oplossingen, van prototype tot productie.' },
    ],
    statNumber: '50+',
    statLabel: 'organisaties geholpen sinds 2019',
  },
  en: {
    h1: 'As seen on national television.',
    lead: 'AI Heroes on De AI Storm, on how Dutch organisations put AI to work. Watch the episode below.',
    cta: 'Book an introduction',
    bridgeHeading: 'From the screen to your organisation',
    bridgeParas: [
      'Across four episodes, De AI Storm shows how organisations treat AI as a tool. Something that simplifies processes, reduces errors and frees up room for the work that genuinely matters.',
      'What you see in our episode is what we do every day. We guide organisations from first exploration to working solution, with training, consulting and software under one roof.',
    ],
    pull: 'AI works when you know how.',
    offerings: [
      { title: 'Training', body: 'Workshops and in-company training that make teams AI-capable.' },
      { title: 'Consulting', body: 'AI-readiness scans, roadmaps and business cases that set direction.' },
      { title: 'Software', body: 'Custom AI solutions, from prototype to production.' },
    ],
    statNumber: '50+',
    statLabel: 'organisations helped since 2019',
  },
};

const t = COPY[lang];
const heading = 'font-sans text-3xl md:text-[40px] leading-[1.1] font-medium tracking-[-0.02em]';
---

<!-- Hero (dark, cinematic). pt clears the fixed white navbar. -->
<header id="page-hero" class="relative overflow-hidden bg-brand-dark text-white">
  <div
    class="pointer-events-none absolute inset-0"
    style="background-image: radial-gradient(60% 55% at 50% -5%, rgba(217,83,79,0.20), transparent 70%), radial-gradient(40% 40% at 90% 10%, rgba(37,99,235,0.10), transparent 70%);"
    aria-hidden="true"
  >
  </div>

  <div class="relative max-w-5xl mx-auto px-6 pt-28 pb-14 md:pt-48 md:pb-20">
    <img
      src="/broadcasters/ai-storm-wit.png"
      alt="De AI Storm"
      width="1250"
      height="250"
      class="h-9 md:h-12 w-auto mb-10"
      style="background-color: transparent"
    />
    <h1 class="font-sans font-medium tracking-[-0.02em] leading-[1.05] text-[34px] sm:text-[44px] md:text-[56px] lg:text-[64px] max-w-3xl text-balance">
      {t.h1}
    </h1>
    <p class="mt-7 max-w-xl text-[17px] md:text-[19px] leading-[1.7] text-white/75 text-pretty">{t.lead}</p>
    <div class="mt-10">
      <a
        href={contactHref}
        class="inline-flex items-center gap-2 bg-brand-red text-white px-7 py-3.5 font-medium shadow-lg shadow-brand-red/20 hover:opacity-90 transition-opacity"
      >
        {t.cta}<span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</header>

<!-- Video (continues the dark block) — the centrepiece, no labels. -->
<section id="video" class="bg-brand-dark text-white scroll-mt-24">
  <div class="max-w-5xl mx-auto px-6 pb-20 md:pb-28">
    <div class="relative aspect-video w-full overflow-hidden rounded-xl border border-white/15 bg-black shadow-2xl ring-1 ring-white/5">
      <iframe
        class="absolute inset-0 h-full w-full"
        src={`https://www.youtube-nocookie.com/embed/${VIDEO_ID}?rel=0`}
        title="AI Heroes · De AI Storm"
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen></iframe>
    </div>
  </div>
</section>

<!-- Broadcaster logos — the trust signal, stated once. -->
<section class="bg-white border-y border-stone-200">
  <div class="max-w-4xl mx-auto px-6 py-14 md:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 md:gap-6">
      {
        LOGOS.map((l) => (
          <div class="h-[104px] md:h-[116px] border border-stone-200 bg-white flex items-center justify-center px-8">
            <img
              src={l.src}
              alt={l.name}
              class="max-h-[38px] md:max-h-[44px] w-auto max-w-[170px] md:max-w-[200px] object-contain"
              style="background-color: transparent"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- From the screen to your organisation. -->
<section class="bg-brand-sand">
  <div class="max-w-5xl mx-auto px-6 py-20 md:py-28">
    <div class="max-w-3xl">
      <h2 class={heading}>{t.bridgeHeading}</h2>
      <div class="mt-8 space-y-6 text-[17px] md:text-[18px] leading-[1.75] text-stone-700">
        {t.bridgeParas.map((p) => <p>{p}</p>)}
      </div>
      <p class="mt-12 font-serif italic text-[26px] md:text-[34px] leading-[1.35] text-brand-dark text-balance">
        {t.pull}
      </p>
    </div>

    <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-x-10 gap-y-8 border-t border-stone-300 pt-12">
      {
        t.offerings.map((o) => (
          <div>
            <h3 class="font-sans text-lg font-medium text-brand-dark">{o.title}</h3>
            <p class="mt-2 text-[15px] leading-relaxed text-stone-600">{o.body}</p>
          </div>
        ))
      }
    </div>

    <div class="mt-14 flex items-baseline gap-4">
      <span class="font-serif text-5xl md:text-6xl text-brand-red leading-none">{t.statNumber}</span>
      <span class="text-base text-stone-600">{t.statLabel}</span>
    </div>
  </div>
</section>

<!-- Contact — the single conversion endpoint (lead source tagged). -->
<section id="contact-form" class="bg-white border-t border-stone-200 scroll-mt-24">
  <div class="max-w-3xl mx-auto px-6 py-20 md:py-28">
    <PageContactForm lang={lang} accentColor="red" preselectedTopic="De AI Storm" client:visible />
  </div>
</section>

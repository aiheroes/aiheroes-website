---
import { Logo } from '../../../components/Logo';
import { CONTENT } from '../../data/content';
import { alternatePath, type Lang } from '../../data/i18n';

interface Props {
  lang: Lang;
  path: string;
}
const { lang, path } = Astro.props;
const nav = CONTENT[lang].nav;
const altUrl = alternatePath(path, lang);

const homeHref = lang === 'nl' ? '/' : '/en';
const contactHref = lang === 'nl' ? '/#contact' : '/en#contact';
const links = [
  { label: nav.services.label, href: lang === 'nl' ? '/nl/diensten' : '/en/services' },
  { label: nav.about.label, href: lang === 'nl' ? '/nl/over-ons' : '/en/about' },
  { label: nav.resources.label, href: lang === 'nl' ? '/nl/resources' : '/en/resources' },
];
const ctaLabel = lang === 'nl' ? 'Start gesprek' : 'Start conversation';
---

<header
  id="site-navbar"
  data-navbar
  class="fixed top-0 inset-x-0 z-50 navbar-clear navbar-clear-dark"
>
  <div class="max-w-7xl 2xl:max-w-[88rem] mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <a href={homeHref} class="flex items-center" aria-label="AI Heroes home">
        <Logo className="h-10 w-auto" variant="logo" colorVariant="white" data-navbar-logo />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-8" data-navbar-links>
        {links.map((l) => (
          <a href={l.href} class="text-sm font-medium text-white/90 hover:text-white transition-colors">{l.label}</a>
        ))}
        <div class="flex items-center gap-2 text-sm">
          {lang === 'nl' ? <span class="font-bold text-white">NL</span> : <a href={altUrl} class="text-white/70 hover:text-white">NL</a>}
          <span class="text-white/30">|</span>
          {lang === 'en' ? <span class="font-bold text-white">EN</span> : <a href={altUrl} class="text-white/70 hover:text-white">EN</a>}
        </div>
        <a href={contactHref} class="bg-brand-red text-white px-5 py-2.5 text-sm font-medium hover:bg-opacity-90 transition-all">{ctaLabel}</a>
      </nav>

      <!-- Mobile toggle -->
      <button type="button" data-navbar-toggle class="md:hidden text-white p-2" aria-label="Menu" aria-expanded="false">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div data-navbar-mobile class="md:hidden hidden bg-brand-dark border-t border-stone-800">
    <nav class="px-6 py-4 flex flex-col gap-3">
      {links.map((l) => (
        <a href={l.href} class="text-white/90 py-1">{l.label}</a>
      ))}
      <a href={contactHref} class="bg-brand-red text-white px-5 py-3 text-center font-medium mt-2">{ctaLabel}</a>
      <div class="flex items-center gap-3 pt-2 text-white/80">
        {lang === 'nl' ? <span class="font-bold text-white">NL</span> : <a href={altUrl}>NL</a>}
        <span class="text-white/30">|</span>
        {lang === 'en' ? <span class="font-bold text-white">EN</span> : <a href={altUrl}>EN</a>}
      </div>
    </nav>
  </div>
</header>
<!-- Spacer so fixed nav doesn't overlap content that isn't a full-bleed dark hero. -->

<script>
  // Lightweight nav behaviour (no framework runtime). Re-runs after View Transitions.
  function initNavbar() {
    const bar = document.querySelector('[data-navbar]') as HTMLElement | null;
    if (!bar) return;
    const toggle = bar.querySelector('[data-navbar-toggle]');
    const mobile = bar.querySelector('[data-navbar-mobile]');

    // Solid background once scrolled away from the top.
    const onScroll = () => {
      const scrolled = window.scrollY > 24;
      bar.classList.toggle('navbar-clear', !scrolled);
      bar.classList.toggle('navbar-clear-dark', !scrolled);
      bar.classList.toggle('navbar-blur', scrolled);
      bar.classList.toggle('navbar-blur-dark', scrolled);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    toggle?.addEventListener('click', () => {
      const open = mobile?.classList.toggle('hidden');
      toggle.setAttribute('aria-expanded', String(open === false));
    });
  }
  initNavbar();
  document.addEventListener('astro:after-swap', initNavbar);
</script>

---
import { Logo } from '../../../components/Logo';
import { CONTENT } from '../../data/content';
import { alternatePath, type Lang } from '../../data/i18n';

interface Props {
  lang: Lang;
  path: string;
}
const { lang, path } = Astro.props;
const nav = CONTENT[lang].nav;
const altUrl = alternatePath(path, lang);

const homeHref = lang === 'nl' ? '/' : '/en';
const contactHref = lang === 'nl' ? '/#contact' : '/en#contact';
const aiSalonHref = lang === 'nl' ? '/nl/ai-salon' : '/en/ai-salon';
const casesHref = lang === 'nl' ? '/nl/cases' : '/en/cases';
const servicesHref = lang === 'nl' ? '/nl/diensten' : '/en/services';

const services = nav.services.children ?? [];
const trainingItems = services.filter((c) => c.category === 'training');
const consultingItems = services.filter((c) => c.category === 'consulting');
const softwareItems = services.filter((c) => c.category === 'software');

const pillarMeta =
  lang === 'nl'
    ? {
        training: { label: 'TRAINING', subtitle: 'Workshops die bijblijven', href: '/nl/diensten/training', color: 'text-brand-red' },
        consulting: { label: 'CONSULTANCY', subtitle: 'Van inzicht naar strategie', href: '/nl/diensten/consultancy', color: 'text-brand-blue' },
        software: { label: 'SOFTWARE', subtitle: 'Van plan naar oplossing', href: '/nl/diensten/software', color: 'text-stone-700' },
      }
    : {
        training: { label: 'TRAINING', subtitle: 'Workshops that stick', href: '/en/services/training', color: 'text-brand-red' },
        consulting: { label: 'CONSULTING', subtitle: 'From insight to strategy', href: '/en/services/consulting', color: 'text-brand-blue' },
        software: { label: 'SOFTWARE', subtitle: 'From plan to solution', href: '/en/services/software', color: 'text-stone-700' },
      };
const pillarColumns = [
  { meta: pillarMeta.training, items: trainingItems, hover: 'hover:text-brand-red' },
  { meta: pillarMeta.consulting, items: consultingItems, hover: 'hover:text-brand-blue' },
  { meta: pillarMeta.software, items: softwareItems, hover: 'hover:text-stone-900' },
];

const allServicesLabel = lang === 'nl' ? 'Bekijk alle diensten' : 'View all services';
const aboutTopLabel = lang === 'nl' ? 'Over AI Heroes' : 'About AI Heroes';
const aboutColumns = nav.about.columns ?? [];
// Mobile accordion shows the full grouped set (incl. AI Salon + TV), not the
// lean footer-facing children.
const aboutItems = aboutColumns.flatMap((c) => c.items);

const featured = nav.featured;
const contactLabel = nav.contact.label;

// EU flag (12-star ring), computed at build time. Mirrors the React featured icon.
const euStars = Array.from({ length: 12 }, (_, i) => {
  const a = ((i * 30 - 90) * Math.PI) / 180;
  return { x: 405 + 140 * Math.cos(a), y: 270 + 140 * Math.sin(a) };
});
const euStarPoints = (s: { x: number; y: number }) =>
  `${s.x},${s.y - 20} ${s.x + 6},${s.y - 6} ${s.x + 19},${s.y - 6} ${s.x + 9},${s.y + 3} ${s.x + 12},${s.y + 17} ${s.x},${s.y + 9} ${s.x - 12},${s.y + 17} ${s.x - 9},${s.y + 3} ${s.x - 19},${s.y - 6} ${s.x - 6},${s.y - 6}`;

---

<header id="site-navbar" data-navbar class="fixed top-0 inset-x-0 z-50">
  <!-- Background + blur live on a separate layer, NOT on the <header>. A non-`none`
       backdrop-filter clips its descendants to its own box, which would hide the
       mega-menu panels that hang below the bar. Keeping the filter on a sibling
       layer (behind the content via z-[-10]) lets the panels overflow freely. -->
  <div data-navbar-bg aria-hidden="true" class="absolute inset-x-0 top-0 h-24 z-[-10] navbar-clear navbar-clear-dark"></div>
  <div class="max-w-7xl 2xl:max-w-[88rem] mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-24">
      <a href={homeHref} class="flex items-center" aria-label="AI Heroes home">
        <Logo className="h-16 w-auto" variant="wordmark" colorVariant="white" />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-8">
        <!-- Services mega-menu -->
        <div class="group relative">
          <a href={servicesHref} class="flex items-center gap-1 text-sm font-medium text-white/90 hover:text-white transition-colors py-2">
            {nav.services.label}
            <svg class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </a>
          <div class="absolute top-full left-1/2 -translate-x-1/2 pt-3 w-[720px] max-w-[calc(100vw-2rem)] opacity-0 invisible translate-y-1 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 group-focus-within:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 transition-all duration-200">
            <div class="bg-white rounded-lg shadow-xl border border-stone-200 p-5">
              <div class="mb-4 pb-3 border-b border-stone-100">
                <a href={servicesHref} class="inline-flex items-center gap-1.5 text-sm text-stone-500 hover:text-brand-red transition-colors">
                  {allServicesLabel}
                  <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              </div>
              <div class="grid grid-cols-3 gap-6">
                {pillarColumns.map((col) => (
                  <div>
                    <a href={col.meta.href} class="block mb-3">
                      <span class={`text-xs font-bold tracking-wider ${col.meta.color}`}>{col.meta.label}</span>
                      <span class="block text-xs text-stone-400 mt-0.5">{col.meta.subtitle}</span>
                    </a>
                    <div class="space-y-0.5">
                      {col.items.map((item) => (
                        <a href={item.href} class={`block px-2 py-1.5 text-sm text-brand-dark ${col.hover} hover:bg-stone-50 rounded transition-colors`}>{item.label}</a>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
              {featured && (
                <div class="mt-4 pt-4 border-t border-stone-100">
                  <a href={featured.href} class="group/feat flex items-center gap-3 px-3 py-2.5 rounded hover:bg-stone-50 transition-colors">
                    <svg viewBox="0 0 810 540" class="w-6 h-4 flex-shrink-0 rounded-[2px]" aria-label="EU">
                      <rect width="810" height="540" fill="#003399" />
                      {euStars.map((s) => <polygon points={euStarPoints(s)} fill="#FFCC00" />)}
                    </svg>
                    <span class="flex-1 min-w-0">
                      <span class="block text-sm font-medium text-brand-dark group-hover/feat:text-brand-red transition-colors">{featured.label}</span>
                      <span class="block text-xs text-stone-400 mt-0.5">{featured.description}</span>
                    </span>
                    <svg class="w-3.5 h-3.5 text-stone-400 group-hover/feat:text-brand-red group-hover/feat:translate-x-0.5 transition-all flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </a>
                </div>
              )}
            </div>
          </div>
        </div>

        <!-- Over ons mega-menu (grouped columns) -->
        <div class="group relative">
          <a href={nav.about.href} class="flex items-center gap-1 text-sm font-medium text-white/90 hover:text-white transition-colors py-2">
            {nav.about.label}
            <svg class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </a>
          <div class="absolute top-full left-1/2 -translate-x-1/2 pt-3 w-[600px] max-w-[calc(100vw-2rem)] opacity-0 invisible translate-y-1 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 group-focus-within:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 transition-all duration-200">
            <div class="bg-white rounded-lg shadow-xl border border-stone-200 p-5">
              <div class="mb-4 pb-3 border-b border-stone-100">
                <a href={nav.about.href} class="inline-flex items-center gap-1.5 text-sm text-stone-500 hover:text-brand-red transition-colors">
                  {aboutTopLabel}
                  <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              </div>
              <div class="grid grid-cols-3 gap-6">
                {aboutColumns.map((col) => (
                  <div>
                    <div class="text-xs font-bold uppercase tracking-wider text-stone-400 mb-3">{col.heading}</div>
                    <div class="space-y-0.5">
                      {col.items.map((item) => (
                        <a href={item.href} class="block px-2 py-1.5 rounded hover:bg-stone-50 transition-colors group/it">
                          <span class="block text-sm text-brand-dark group-hover/it:text-brand-red transition-colors">{item.label}</span>
                          {item.description && <span class="block text-xs text-stone-400 mt-0.5">{item.description}</span>}
                        </a>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        <a href={casesHref} class="text-sm font-medium text-white/90 hover:text-white transition-colors py-2">Cases</a>

        <a href={aiSalonHref} class="text-sm font-medium text-white/90 hover:text-white transition-colors py-2">AI Salon</a>

        <a href={contactHref} class="bg-white text-brand-dark px-5 py-2 text-sm font-medium rounded-sm hover:bg-stone-200 transition-colors">{contactLabel}</a>

        <div class="flex items-center gap-2 text-xs font-bold uppercase tracking-wider">
          {lang === 'nl' ? <span class="text-white underline underline-offset-4">NL</span> : <a href={altUrl} class="text-white/50 hover:text-white">NL</a>}
          <span class="text-white/30">/</span>
          {lang === 'en' ? <span class="text-white underline underline-offset-4">EN</span> : <a href={altUrl} class="text-white/50 hover:text-white">EN</a>}
        </div>
      </nav>

      <!-- Mobile toggle -->
      <button type="button" data-navbar-toggle class="md:hidden text-white p-2" aria-label="Menu" aria-expanded="false">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu (full-screen accordion) -->
  <div data-navbar-mobile class="md:hidden hidden bg-brand-light max-h-[calc(100vh-6rem)] overflow-y-auto">
    <nav class="px-6 py-4">
      <!-- Services accordion with pillar groups -->
      <div class="border-b border-stone-200">
        <button type="button" data-acc-toggle aria-expanded="false" class="w-full flex justify-between items-center py-4 text-2xl font-serif font-medium text-brand-dark">
          {nav.services.label}
          <svg class="w-6 h-6 transition-transform" data-acc-chevron viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div data-acc-panel class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out" inert>
          <div class="overflow-hidden">
            <div class="pb-4 space-y-4">
              {pillarColumns.map((col) => (
                <div>
                  <div class={`text-xs font-bold uppercase tracking-wider mb-2 ${col.meta.color}`}>{col.meta.label}</div>
                  <div class="pl-2 space-y-2">
                    {col.items.map((item) => (
                      <a href={item.href} class="block text-base text-stone-600">{item.label}</a>
                    ))}
                  </div>
                </div>
              ))}
              {featured && (
                <a href={featured.href} class="flex items-center gap-3 pt-3 mt-1 border-t border-stone-200">
                  <svg viewBox="0 0 810 540" class="w-6 h-4 flex-shrink-0 rounded-[2px]" aria-label="EU"><rect width="810" height="540" fill="#003399" />{euStars.map((s) => <polygon points={euStarPoints(s)} fill="#FFCC00" />)}</svg>
                  <span><span class="block text-base text-brand-dark">{featured.label}</span><span class="block text-xs text-stone-400">{featured.description}</span></span>
                </a>
              )}
            </div>
          </div>
        </div>
      </div>

      <!-- Over ons accordion -->
      <div class="border-b border-stone-200">
        <button type="button" data-acc-toggle aria-expanded="false" class="w-full flex justify-between items-center py-4 text-2xl font-serif font-medium text-brand-dark">
          {nav.about.label}
          <svg class="w-6 h-6 transition-transform" data-acc-chevron viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div data-acc-panel class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out" inert>
          <div class="overflow-hidden">
            <div class="pb-4 pl-2 space-y-3">
              {aboutItems.map((item) => (
                <a href={item.href} class="block text-base text-stone-600">{item.label}</a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <a href={casesHref} class="flex justify-between items-center py-4 text-2xl font-serif font-medium text-brand-dark border-b border-stone-200">Cases</a>

      <a href={aiSalonHref} class="flex justify-between items-center py-4 text-2xl font-serif font-medium text-brand-dark border-b border-stone-200">AI Salon</a>

      <a href={contactHref} class="block w-full bg-brand-red text-white text-center py-4 text-xl font-medium mt-6">{contactLabel}</a>

      <div class="mt-8 flex gap-4 text-lg border-t border-stone-300 pt-8">
        {lang === 'nl' ? <span class="font-bold text-brand-red">NL</span> : <a href={altUrl} class="text-stone-500">NL</a>}
        <span class="text-stone-300">|</span>
        {lang === 'en' ? <span class="font-bold text-brand-red">EN</span> : <a href={altUrl} class="text-stone-500">EN</a>}
      </div>
    </nav>
  </div>
</header>

<script>
  // Compact navbar behaviour: scroll-bg toggle + mobile menu + accordions.
  // Vanilla (no framework runtime); re-runs after View Transitions.
  function initNavbar() {
    const bar = document.querySelector('[data-navbar]') as HTMLElement | null;
    if (!bar) return;
    const bg = bar.querySelector('[data-navbar-bg]');
    const toggle = bar.querySelector('[data-navbar-toggle]');
    const mobile = bar.querySelector('[data-navbar-mobile]');

    const onScroll = () => {
      const scrolled = window.scrollY > 24;
      bg?.classList.toggle('navbar-clear', !scrolled);
      bg?.classList.toggle('navbar-clear-dark', !scrolled);
      bg?.classList.toggle('navbar-blur', scrolled);
      bg?.classList.toggle('navbar-blur-dark', scrolled);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    toggle?.addEventListener('click', () => {
      const hidden = mobile?.classList.toggle('hidden');
      toggle.setAttribute('aria-expanded', String(hidden === false));
    });

    // Accordion toggles inside the mobile menu. Animate the panel height via the
    // grid-rows 0fr<->1fr trick (set inline so it overrides the collapsed class).
    bar.querySelectorAll('[data-acc-toggle]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const panel = btn.nextElementSibling as HTMLElement | null;
        if (!panel) return;
        const chevron = btn.querySelector('[data-acc-chevron]');
        const willOpen = panel.style.gridTemplateRows !== '1fr';
        panel.style.gridTemplateRows = willOpen ? '1fr' : '0fr';
        panel.toggleAttribute('inert', !willOpen);
        btn.setAttribute('aria-expanded', String(willOpen));
        chevron?.classList.toggle('rotate-180', willOpen);
      });
    });
  }
  initNavbar();
  document.addEventListener('astro:after-swap', initNavbar);
</script>

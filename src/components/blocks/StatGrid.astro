---
/** A row of headline stats. Big serif number + uppercase label. */
interface Props {
  stats: { value: string; label: string }[];
  accent?: 'red' | 'blue';
  cols?: 2 | 3 | 4;
  variant?: 'light' | 'dark';
  class?: string;
}
const { stats, accent = 'red', cols = 3, variant = 'light', class: className = '' } = Astro.props;
const accentText = accent === 'red' ? 'text-brand-red' : 'text-brand-blue';
const colClass = { 2: 'grid-cols-1 sm:grid-cols-2', 3: 'grid-cols-1 sm:grid-cols-3', 4: 'grid-cols-2 md:grid-cols-4' }[cols];
const card = variant === 'dark' ? 'bg-white/[0.04] border-white/10' : 'bg-white border-stone-200';
const label = variant === 'dark' ? 'text-white/50' : 'text-stone-500';
---
<div class={`grid ${colClass} gap-4 ${className}`}>
  {stats.map((s) => (
    <div class={`text-center p-6 border ${card}`}>
      <div class={`text-3xl md:text-4xl font-serif ${accentText} mb-2`}>{s.value}</div>
      <div class={`text-sm uppercase tracking-wider ${label}`}>{s.label}</div>
    </div>
  ))}
</div>

---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { hreflangPaths, alternatePath, type Lang } from '../data/i18n';
import { PROFESSIONAL_SERVICE_SCHEMA } from '../data/schema';
import { CONTENT } from '../data/content';
// Single source of truth for the navbar AND footer: the legacy React
// components. The navbar hydrates (client:load) for dropdowns, mobile menu and
// the scroll-split theming; the footer stays server-rendered with NO client
// directive (static HTML, zero JS) — its language toggle is a plain <a href>.
import NavbarIsland from '../components/islands/NavbarIsland';
import { Footer } from '../../components/Footer';

export interface Props {
  lang: Lang;
  title: string;
  /** Overrides the visible-title-derived <title> for keyword targeting only. */
  seoTitle?: string;
  description: string;
  noindex?: boolean;
  jsonLd?: object | object[];
  ogImage?: string;
  /** Skip the Astro Navbar + Footer (e.g. the homepage island renders its own). */
  noChrome?: boolean;
}

const {
  lang,
  title,
  seoTitle,
  description,
  noindex = false,
  jsonLd,
  ogImage = '/og-image.png',
  noChrome = false,
} = Astro.props;

const DOMAIN = 'https://aiheroes.io';
// Canonical path: strip the .html suffix (build format 'file') and a trailing
// slash except for the root, so canonicals/hreflang/nav always use clean URLs.
const rawPath = Astro.url.pathname;
const path = rawPath !== '/' ? rawPath.replace(/\.html$/, '').replace(/\/$/, '') : '/';
const canonical = `${DOMAIN}${path}`;
const fullTitle = `${seoTitle ?? title} | AI Heroes`;
const { nl, en, xDefault } = hreflangPaths(path, lang);
const ogLocale = lang === 'nl' ? 'nl_NL' : 'en_US';
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${DOMAIN}${ogImage}`;
const pageSchemas = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
// Organization schema ships on every page (entity grounding for search + AI engines),
// unless the page provides its own org-level block (e.g. a LocalBusiness variant).
const ORG_TYPES = ['ProfessionalService', 'LocalBusiness', 'Organization'];
const hasOwnOrgSchema = pageSchemas.some((s) => ORG_TYPES.includes(s['@type']));
const schemas = hasOwnOrgSchema ? pageSchemas : [PROFESSIONAL_SERVICE_SCHEMA, ...pageSchemas];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Favicons (light) -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
    <!-- Favicons (dark, auto-swap on OS theme) -->
    <link rel="icon" href="/favicon-white.ico" sizes="any" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-white-16.png" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-white-32.png" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-white-48.png" media="(prefers-color-scheme: dark)" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-white-180.png" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-white-512.png" media="(prefers-color-scheme: dark)" />
    <link rel="preload" as="image" href="/hero-bg.webp" type="image/webp" />

    <!-- Primary meta -->
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    <meta name="author" content="AI Heroes" />
    <meta name="google-site-verification" content="cDwNcWtvIDJx0kC5rIDIanesLuEY6_aVipJl-fZRdZI" />
    <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow'} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={lang === 'nl' ? 'en_US' : 'nl_NL'} />
    <meta property="og:site_name" content="AI Heroes" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonical} />
    <meta property="twitter:title" content={fullTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImageUrl} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="nl" href={`${DOMAIN}${nl}`} />
    <link rel="alternate" hreflang="en" href={`${DOMAIN}${en}`} />
    <link rel="alternate" hreflang="x-default" href={`${DOMAIN}${xDefault}`} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <!-- Structured data -->
    {schemas.map((schema) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <ClientRouter />

    <script>
      // Anchor deep-links (mega-menu SKU items, retired-SKU 301s) teleport
      // straight into the middle of pillar pages, which reads as "landing
      // mid-page" with no context. Instead: start at the top and run a fast
      // animated scroll down to the section. Skips back/forward navigation so
      // the browser's scroll restoration keeps working.
      let navDirection = 'forward';
      document.addEventListener('astro:before-swap', (e: any) => {
        navDirection = e.direction ?? 'forward';
      });

      function animateToAnchor() {
        if (navDirection !== 'forward' || !location.hash) return;
        const target = document.getElementById(decodeURIComponent(location.hash.slice(1)));
        if (!target) return;
        window.scrollTo({ top: 0, behavior: 'instant' as ScrollBehavior });
        // Fast ease-out scroll (~450ms) — snappier than native smooth scroll.
        const startY = 0;
        const endY = target.getBoundingClientRect().top - 96; // clear the fixed navbar
        const duration = 450;
        const start = performance.now();
        function step(now: number) {
          const t = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - t, 3);
          window.scrollTo(0, startY + (endY - startY) * eased);
          if (t < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      }

      // Client-side (view transition) navigations + full page loads.
      document.addEventListener('astro:after-swap', animateToAnchor);
      if (document.readyState === 'complete') animateToAnchor();
      else window.addEventListener('load', animateToAnchor);
    </script>
  </head>
  <body class="min-h-screen bg-brand-light text-brand-dark font-sans overflow-x-hidden">
    {!noChrome && <NavbarIsland client:load lang={lang} alternateUrl={alternatePath(path, lang)} />}
    <slot />
    {!noChrome && (
      <Footer
        content={CONTENT[lang].footer}
        nav={CONTENT[lang].nav}
        lang={lang}
        alternateUrl={alternatePath(path, lang)}
      />
    )}

    <!-- Hidden form definitions so Netlify detects them at build time (forms post to "/"). -->
    <form name="contact" data-netlify="true" data-netlify-honeypot="bot-field" hidden>
      <input type="text" name="bot-field" />
      <input type="text" name="name" />
      <input type="email" name="email" />
      <input type="text" name="organization" />
      <input type="text" name="topics" />
      <textarea name="message"></textarea>
    </form>
    <form name="application" data-netlify="true" data-netlify-honeypot="bot-field" enctype="multipart/form-data" hidden>
      <input type="text" name="bot-field" />
      <input type="text" name="name" />
      <input type="email" name="email" />
      <input type="tel" name="phone" />
      <input type="text" name="position" />
      <textarea name="motivation"></textarea>
      <input type="file" name="cv" />
    </form>
  </body>
</html>
